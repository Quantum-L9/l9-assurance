{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/assurance/v1/assurancepolicy.schema.json",
  "title": "AssurancePolicy",
  "description": "AssurancePolicy",
  "x-l9-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "controlOverrides": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "controlId": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "mandatory",
              "advisory"
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "waiverAllowed": {
            "type": "boolean"
          }
        },
        "required": [
          "controlId"
        ],
        "unevaluatedProperties": false
      }
    },
    "mandatoryFindingSeverities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "critical",
          "high",
          "medium",
          "low",
          "informational"
        ]
      }
    },
    "unknownHandling": {
      "type": "object",
      "properties": {
        "mandatory": {
          "type": "string",
          "enum": [
            "indeterminate",
            "fail"
          ]
        },
        "advisory": {
          "type": "string",
          "enum": [
            "indeterminate",
            "ignore"
          ]
        }
      },
      "required": [
        "mandatory",
        "advisory"
      ],
      "unevaluatedProperties": false
    },
    "waiverAuthorization": {
      "type": "object",
      "properties": {
        "acceptedRoles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requireSignature": {
          "type": "boolean"
        }
      },
      "required": [
        "acceptedRoles",
        "requireSignature"
      ],
      "unevaluatedProperties": false
    },
    "hardProhibitions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "id",
          "description"
        ],
        "unevaluatedProperties": false
      }
    },
    "minimumPolicyVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:\\.[a-z0-9-]+)+$"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "id",
    "version",
    "title",
    "controlOverrides",
    "mandatoryFindingSeverities",
    "unknownHandling",
    "waiverAuthorization",
    "hardProhibitions"
  ],
  "unevaluatedProperties": false
}
