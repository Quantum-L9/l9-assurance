{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/assurance/v1/subjectreference.schema.json",
  "title": "SubjectReference",
  "description": "SubjectReference",
  "x-l9-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "const": "git-revision"
    },
    "repository": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "host",
        "owner",
        "name"
      ],
      "unevaluatedProperties": false
    },
    "revision": {
      "type": "object",
      "properties": {
        "commit": {
          "type": "string",
          "pattern": "^(?:[a-fA-F0-9]{40}|[a-fA-F0-9]{64})$"
        },
        "treeDigest": {
          "$ref": "./digest.schema.json"
        }
      },
      "required": [
        "commit"
      ],
      "unevaluatedProperties": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": [
    "kind",
    "repository",
    "revision"
  ],
  "unevaluatedProperties": false
}
