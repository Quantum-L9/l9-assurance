{
  "name": "@l9/assurance-cli",
  "version": "2.0.1",
  "description": "Offline local-first L9 Assurance command-line interface and engine.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./engine": {
      "types": "./dist/engine.d.ts",
      "import": "./dist/engine.js"
    }
  },
  "files": [
    "dist",
    "protocol"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs').then(({rmSync})=>rmSync('dist',{recursive:true,force:true}))\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@l9/assurance-contracts": "2.0.1",
    "@l9/assurance-evidence": "2.0.1",
    "@l9/assurance-controls": "2.0.1",
    "@l9/assurance-policy": "2.0.1",
    "@l9/assurance-evaluator": "2.0.1",
    "@l9/assurance-conformance": "2.0.1"
  },
  "bin": {
    "l9-assurance": "./dist/bin.js"
  }
}
