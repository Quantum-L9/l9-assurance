{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/assurance/v1/artifactreference.schema.json",
  "title": "ArtifactReference",
  "description": "ArtifactReference",
  "x-l9-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "digest": {
      "$ref": "./digest.schema.json"
    },
    "mediaType": {
      "type": "string",
      "minLength": 1
    },
    "path": {
      "type": "string",
      "minLength": 1
    },
    "uri": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "name",
    "digest"
  ],
  "unevaluatedProperties": false
}
