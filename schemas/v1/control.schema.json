{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/assurance/v1/controldefinition.schema.json",
  "title": "ControlDefinition",
  "description": "ControlDefinition",
  "x-l9-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "mandatory",
        "advisory"
      ]
    },
    "applicability": {
      "type": "object",
      "properties": {
        "subjectKind": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "subjectKind"
      ],
      "unevaluatedProperties": false
    },
    "evidenceRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "producer": {
            "type": "string",
            "minLength": 1
          },
          "check": {
            "type": "string",
            "minLength": 1
          },
          "minimumCheckVersion": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "acceptedExecutionStatus": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "passed",
                "failed",
                "error",
                "skipped"
              ]
            },
            "minItems": 1
          },
          "cardinality": {
            "type": "object",
            "properties": {
              "minimum": {
                "type": "integer",
                "minimum": 0
              },
              "maximum": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "minimum",
              "maximum"
            ],
            "unevaluatedProperties": false
          },
          "subjectBinding": {
            "type": "object",
            "properties": {
              "exactRevision": {
                "type": "boolean"
              }
            },
            "required": [
              "exactRevision"
            ],
            "unevaluatedProperties": false
          },
          "freshness": {
            "type": "object",
            "properties": {
              "mode": {
                "type": "string",
                "enum": [
                  "revision-bound",
                  "duration"
                ]
              },
              "maximumAgeSeconds": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "mode"
            ],
            "unevaluatedProperties": false
          }
        },
        "required": [
          "producer",
          "check",
          "acceptedExecutionStatus",
          "cardinality",
          "subjectBinding"
        ],
        "unevaluatedProperties": false
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          }
        },
        "required": [
          "id",
          "version"
        ],
        "unevaluatedProperties": false
      }
    },
    "evaluation": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "all-requirements-satisfied",
            "no-matching-findings",
            "exact-subject-consistency"
          ]
        },
        "mandatoryFindingSeverities": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low",
              "informational"
            ]
          }
        }
      },
      "required": [
        "type"
      ],
      "unevaluatedProperties": false
    },
    "freshness": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "revision-bound",
            "duration"
          ]
        },
        "maximumAgeSeconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "mode"
      ],
      "unevaluatedProperties": false
    },
    "waiver": {
      "type": "object",
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "requiredRoles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "maximumDurationSeconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "allowed"
      ],
      "unevaluatedProperties": false
    }
  },
  "required": [
    "id",
    "version",
    "claim",
    "title",
    "description",
    "severity",
    "evidenceRequirements",
    "evaluation"
  ],
  "unevaluatedProperties": false
}
