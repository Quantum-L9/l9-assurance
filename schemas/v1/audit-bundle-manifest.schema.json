{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.quantum-l9.dev/assurance/v1/auditbundlemanifest.schema.json",
  "title": "AuditBundleManifest",
  "description": "AuditBundleManifest",
  "x-l9-schema-version": "1.0.0",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "l9.audit-bundle-manifest"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "decisionId": {
      "type": "string",
      "minLength": 1
    },
    "completeness": {
      "type": "string",
      "enum": [
        "complete",
        "partial",
        "review-limited"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "$ref": "./digest.schema.json"
          },
          "mediaType": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "path",
          "digest",
          "role"
        ],
        "unevaluatedProperties": false
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:\\.[a-z0-9-]+)+$"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "schema",
    "schemaVersion",
    "bundleId",
    "decisionId",
    "completeness",
    "entries",
    "createdAt"
  ],
  "unevaluatedProperties": false
}
